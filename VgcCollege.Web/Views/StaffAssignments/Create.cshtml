@model VgcCollege.Domain.Models.FacultyCourse

@{
    ViewData["Title"] = "Assign Faculty to Course";
}

<h1>Assign Faculty to Course</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="FacultyProfileId" class="control-label">Faculty</label>
                <select asp-for="FacultyProfileId" class="form-control" asp-items="ViewBag.FacultyId">
                    <option value="">-- Select Faculty --</option>
                </select>
                <span asp-validation-for="FacultyProfileId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="CourseId" class="control-label">Course</label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId">
                    <option value="">-- Select Course --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Assign" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}