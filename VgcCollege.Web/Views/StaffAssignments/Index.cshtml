@using VgcCollege.Domain.Models
@model List<FacultyCourse>
@{
    ViewData["Title"] = "Staff Assignments";
}

<h2>Staff Assignments</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">+ Assign Faculty to Course</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No staff assignments yet.</div>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-dark">
        <tr>
            <th>Faculty Member</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.Faculty.Name</td>
                <td>@a.Course.Name</td>
                <td>@a.Course.Branch?.Name</td>
                <td>
                    @if (a.IsTutor)
                    {
                        <span class="badge bg-warning text-dark">Tutor</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Lecturer</span>
                    }
                </td>
                <td>
                    <a asp-action="Delete"
                       asp-route-facultyId="@a.FacultyProfileId"
                       asp-route-courseId="@a.CourseId"
                       class="btn btn-sm btn-danger">Remove</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}