@model VgcCollege.Domain.Models.FacultyCourse

@{
    ViewData["Title"] = "Remove Assignment";
}

<h1>Remove Assignment</h1>

<h3>Are you sure you want to remove this assignment?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Faculty</dt>
        <dd class="col-sm-10">@Model.Faculty?.Name</dd>
        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.Course?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="FacultyProfileId" />
        <input type="hidden" asp-for="CourseId" />
        <input type="submit" value="Remove" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>