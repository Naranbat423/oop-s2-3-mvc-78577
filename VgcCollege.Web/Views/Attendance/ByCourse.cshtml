@model IEnumerable<VgcCollege.Domain.Models.CourseEnrolment>

@{
    ViewData["Title"] = "Attendance - " + ViewBag.CourseName;
    int currentWeek = (int)ViewBag.WeekNumber;
    var allWeeks = ViewBag.AllWeeks as List<int> ?? new List<int>();
}

<h2>Attendance — @ViewBag.CourseName</h2>
<p class="text-muted">Week @currentWeek</p>

@* Week selector *@
<form method="get" asp-action="ByCourse" class="mb-4">
    <input type="hidden" name="courseId" value="@ViewBag.CourseId" />
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">Select Week</label>
            <select name="weekNumber" class="form-select">
                @foreach (int w in allWeeks)
                {
                    if (w == currentWeek)
                    {
                        <option value="@w" selected="selected">Week @w</option>
                    }
                    else
                    {
                        <option value="@w">Week @w</option>
                    }
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Load</button>
        </div>
    </div>
</form>

@* Attendance form *@
<form method="post" asp-action="Save">
    @Html.AntiForgeryToken()
    <input type="hidden" name="courseId" value="@ViewBag.CourseId" />
    <input type="hidden" name="weekNumber" value="@currentWeek" />

    @* Send all enrolment IDs so controller knows the full list *@
    @foreach (var enrolment in Model)
    {
        <input type="hidden" name="allEnrolmentIds" value="@enrolment.Id" />
    }

    <table class="table table-bordered table-sm">
        <thead class="table-dark">
            <tr>
                <th>Student</th>
                <th class="text-center">Present?</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var enrolment in Model)
            {
                var existing = enrolment.AttendanceRecords
                    .FirstOrDefault(a => a.WeekNumber == currentWeek);
                var isPresent = existing?.Present ?? false;
                <tr>
                    <td>@enrolment.Student?.Name</td>
                    <td class="text-center">
                        @if (isPresent)
                        {
                            <input type="checkbox" name="presentIds" value="@enrolment.Id" class="form-check-input" checked="checked" />
                        }
                        else
                        {
                            <input type="checkbox" name="presentIds" value="@enrolment.Id" class="form-check-input" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-success">Save Attendance</button>
    <a asp-action="SelectCourse" class="btn btn-secondary ms-2">Back to Courses</a>
</form>
