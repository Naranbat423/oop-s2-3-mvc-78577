@model IEnumerable<VgcCollege.Domain.Models.Course>

@{
    ViewData["Title"] = "Select Course - Attendance";
}

<h2>Attendance — Select a Course</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No courses assigned to you.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
        <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Action</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Name</td>
                <td>@course.Branch?.Name</td>
                <td>
                    <a asp-action="ByCourse"
                       asp-route-courseId="@course.Id"
                       class="btn btn-sm btn-primary">Take Attendance</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}