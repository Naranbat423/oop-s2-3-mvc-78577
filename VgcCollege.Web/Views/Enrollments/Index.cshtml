@using VgcCollege.Domain.Models
@model List<CourseEnrolment>
@{
    ViewData["Title"] = "Enrolments";
}

<h2>Enrollments</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">+ Enrol Student</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No enrolments found.</div>
}
else
{
    <table class="table table-bordered table-sm table-hover">
        <thead class="table-dark">
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Enrol Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Student.Name</td>
                <td>@e.Course.Name</td>
                <td>@e.EnrolDate.ToString("dd MMM yyyy")</td>
                <td>
                    <span class="badge bg-@(e.Status == "Active" ? "success" : e.Status == "Completed" ? "primary" : "secondary")">
                        @e.Status
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}