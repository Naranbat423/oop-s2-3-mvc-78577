@model VgcCollege.Domain.Models.CourseEnrolment

@{
    ViewData["Title"] = "Enrolment Details";
}

<h1>Enrolment Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@Model.Student?.Name</dd>
        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.Course?.Name</dd>
        <dt class="col-sm-2">Enrolment Date</dt>
        <dd class="col-sm-10">@Model.EnrolDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>