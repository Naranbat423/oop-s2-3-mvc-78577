@model VgcCollege.Domain.Models.CourseEnrolment

@{
    ViewData["Title"] = "Edit Enrolment";
}

<h1>Edit Enrolment</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentId">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="CourseId" class="control-label">Course</label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId">
                    <option value="">-- Select Course --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EnrolDate" class="control-label"></label>
                <input asp-for="EnrolDate" class="form-control" type="date" />
                <span asp-validation-for="EnrolDate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option>Active</option>
                    <option>Completed</option>
                    <option>Dropped</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}