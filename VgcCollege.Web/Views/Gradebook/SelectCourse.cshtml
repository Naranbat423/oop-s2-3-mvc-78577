@model IEnumerable<VgcCollege.Domain.Models.Course>

@{
    ViewData["Title"] = "Select Course - Gradebook";
}

<h2>Gradebook — Select a Course</h2>
<p class="text-muted">Choose a course to view assignments and student results.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">You are not assigned to any courses yet.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
        <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Name</td>
                <td>@course.Branch?.Name</td>
                <td>
                    <a asp-action="Assignments"
                       asp-route-courseId="@course.Id"
                       class="btn btn-sm btn-primary">View Assignments</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}