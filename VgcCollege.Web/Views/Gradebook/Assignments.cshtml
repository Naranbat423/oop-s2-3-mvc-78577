@model IEnumerable<VgcCollege.Domain.Models.Assignment>

@{
    ViewData["Title"] = "Assignments";
    var course = ViewBag.Course as VgcCollege.Domain.Models.Course;
}

<h2>Assignments — @course?.Name</h2>
<p class="text-muted">Click "Enter/View Results" to record student scores.</p>

<p>
    <a asp-action="SelectCourse" class="btn btn-secondary">← Back to Courses</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No assignments found for this course.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Max Score</th>
            <th>Due Date</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var assignment in Model)
        {
            <tr>
                <td>@assignment.Title</td>
                <td>@assignment.MaxScore</td>
                <td>@assignment.DueDate.ToString("dd MMM yyyy")</td>
                <td>
                    <a asp-action="Results"
                       asp-route-assignmentId="@assignment.Id"
                       class="btn btn-sm btn-primary">Enter / View Results</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}